{
  "$connector_name": "Slack API Connector",
  "$connector_label": "Slack API",
  "$connector_description": "Connector for Slack Web API - provides access to users, conversations, channels, messages, teams, and workspace data. Docs: https://api.slack.com/web",
  "$hostname": "https://slack.com/api",
  "$authentication": "oauth2",
  "$tables": {
    "USERS": {
      "$path": ["/users.list"],
      "$data_path": "members",
      "$pagination": {
        "type": "cursor",
        "cursor_param": "cursor",
        "next_cursor_path": "response_metadata.next_cursor",
        "page_size": 200
      },
      "id": "VARCHAR,$key",
      "team_id": "VARCHAR",
      "name": "VARCHAR",
      "deleted": "BOOLEAN",
      "color": "VARCHAR",
      "real_name": "VARCHAR",
      "tz": "VARCHAR",
      "tz_label": "VARCHAR",
      "tz_offset": "INTEGER",
      "profile[]": {
        "title": "VARCHAR",
        "phone": "VARCHAR",
        "skype": "VARCHAR",
        "real_name": "VARCHAR",
        "real_name_normalized": "VARCHAR",
        "display_name": "VARCHAR",
        "display_name_normalized": "VARCHAR",
        "status_text": "VARCHAR",
        "status_emoji": "VARCHAR",
        "status_expiration": "INTEGER",
        "avatar_hash": "VARCHAR",
        "email": "VARCHAR",
        "first_name": "VARCHAR",
        "last_name": "VARCHAR",
        "image_24": "VARCHAR",
        "image_32": "VARCHAR",
        "image_48": "VARCHAR",
        "image_72": "VARCHAR",
        "image_192": "VARCHAR",
        "image_512": "VARCHAR",
        "team": "VARCHAR"
      },
      "is_admin": "BOOLEAN",
      "is_owner": "BOOLEAN",
      "is_primary_owner": "BOOLEAN",
      "is_restricted": "BOOLEAN",
      "is_ultra_restricted": "BOOLEAN",
      "is_bot": "BOOLEAN",
      "is_app_user": "BOOLEAN",
      "updated": "BIGINT",
      "is_email_confirmed": "BOOLEAN",
      "who_can_share_contact_card": "VARCHAR",
      "locale": "VARCHAR"
    },
    "CONVERSATIONS": {
      "$path": ["/conversations.list"],
      "$data_path": "channels",
      "$pagination": {
        "type": "cursor",
        "cursor_param": "cursor",
        "next_cursor_path": "response_metadata.next_cursor",
        "page_size": 200
      },
      "id": "VARCHAR,$key",
      "name": "VARCHAR",
      "is_channel": "BOOLEAN",
      "is_group": "BOOLEAN",
      "is_im": "BOOLEAN",
      "is_mpim": "BOOLEAN",
      "is_private": "BOOLEAN",
      "created": "BIGINT",
      "is_archived": "BOOLEAN",
      "is_general": "BOOLEAN",
      "unlinked": "INTEGER",
      "name_normalized": "VARCHAR",
      "is_shared": "BOOLEAN",
      "is_org_shared": "BOOLEAN",
      "is_pending_ext_shared": "BOOLEAN",
      "pending_shared": "VARCHAR",
      "context_team_id": "VARCHAR",
      "updated": "BIGINT",
      "parent_conversation": "VARCHAR",
      "creator": "VARCHAR",
      "is_ext_shared": "BOOLEAN",
      "shared_team_ids": "VARCHAR",
      "pending_connected_team_ids": "VARCHAR",
      "is_member": "BOOLEAN",
      "topic[]": {
        "value": "VARCHAR",
        "creator": "VARCHAR",
        "last_set": "BIGINT"
      },
      "purpose[]": {
        "value": "VARCHAR",
        "creator": "VARCHAR",
        "last_set": "BIGINT"
      },
      "previous_names": "VARCHAR",
      "num_members": "INTEGER",
      "locale": "VARCHAR"
    },
    "TEAM_INFO": {
      "$path": ["/team.info"],
      "$data_path": "team",
      "id": "VARCHAR,$key",
      "name": "VARCHAR",
      "domain": "VARCHAR",
      "email_domain": "VARCHAR",
      "icon": "VARCHAR",
      "enterprise_id": "VARCHAR",
      "enterprise_name": "VARCHAR",
      "is_verified": "BOOLEAN",
      "discoverable": "VARCHAR"
    },
    "USERGROUPS": {
      "$path": ["/usergroups.list"],
      "$data_path": "usergroups",
      "id": "VARCHAR,$key",
      "team_id": "VARCHAR",
      "is_usergroup": "BOOLEAN",
      "is_subteam": "BOOLEAN",
      "name": "VARCHAR",
      "description": "VARCHAR",
      "handle": "VARCHAR",
      "is_external": "BOOLEAN",
      "date_create": "BIGINT",
      "date_update": "BIGINT",
      "date_delete": "BIGINT",
      "auto_provision": "BOOLEAN",
      "enterprise_subteam_id": "VARCHAR",
      "created_by": "VARCHAR",
      "updated_by": "VARCHAR",
      "deleted_by": "VARCHAR",
      "prefs[]": {
        "channels": "VARCHAR",
        "groups": "VARCHAR"
      },
      "users": "VARCHAR",
      "user_count": "INTEGER",
      "channel_count": "INTEGER"
    },
    "FILES": {
      "$path": ["/files.list"],
      "$data_path": "files",
      "$pagination": {
        "type": "page",
        "page_param": "page",
        "limit_param": "count",
        "page_size": 100,
        "initial_page": 1
      },
      "id": "VARCHAR,$key",
      "created": "BIGINT",
      "timestamp": "BIGINT",
      "name": "VARCHAR",
      "title": "VARCHAR",
      "mimetype": "VARCHAR",
      "filetype": "VARCHAR",
      "pretty_type": "VARCHAR",
      "user": "VARCHAR",
      "user_team": "VARCHAR",
      "editable": "BOOLEAN",
      "size": "INTEGER",
      "mode": "VARCHAR",
      "is_external": "BOOLEAN",
      "external_type": "VARCHAR",
      "is_public": "BOOLEAN",
      "public_url_shared": "BOOLEAN",
      "display_as_bot": "BOOLEAN",
      "username": "VARCHAR",
      "url_private": "VARCHAR",
      "url_private_download": "VARCHAR",
      "permalink": "VARCHAR",
      "permalink_public": "VARCHAR",
      "edit_link": "VARCHAR",
      "preview": "VARCHAR",
      "preview_highlight": "VARCHAR",
      "lines": "INTEGER",
      "lines_more": "INTEGER",
      "preview_is_truncated": "BOOLEAN",
      "comments_count": "INTEGER",
      "is_starred": "BOOLEAN",
      "shares": "VARCHAR",
      "channels": "VARCHAR",
      "groups": "VARCHAR",
      "ims": "VARCHAR",
      "has_rich_preview": "BOOLEAN",
      "file_access": "VARCHAR"
    },
    "REMINDERS": {
      "$path": ["/reminders.list"],
      "$data_path": "reminders",
      "id": "VARCHAR,$key",
      "creator": "VARCHAR",
      "user": "VARCHAR",
      "text": "VARCHAR",
      "recurring": "BOOLEAN",
      "time": "BIGINT",
      "complete_ts": "BIGINT"
    },
    "STARS": {
      "$path": ["/stars.list"],
      "$data_path": "items",
      "$pagination": {
        "type": "page",
        "page_param": "page",
        "limit_param": "count",
        "page_size": 100,
        "initial_page": 1
      },
      "ROWID": "VARCHAR,$key",
      "type": "VARCHAR",
      "channel": "VARCHAR",
      "message": "VARCHAR",
      "file": "VARCHAR",
      "comment": "VARCHAR",
      "date_create": "BIGINT"
    },
    "REACTIONS": {
      "$path": ["/reactions.list"],
      "$data_path": "items",
      "$pagination": {
        "type": "cursor",
        "cursor_param": "cursor",
        "next_cursor_path": "response_metadata.next_cursor",
        "page_size": 100
      },
      "ROWID": "VARCHAR,$key",
      "type": "VARCHAR",
      "channel": "VARCHAR",
      "message": "VARCHAR",
      "file": "VARCHAR",
      "comment": "VARCHAR"
    },
    "ADMIN_TEAMS": {
      "$path": ["/admin.teams.list"],
      "$data_path": "teams",
      "$pagination": {
        "type": "cursor",
        "cursor_param": "cursor",
        "next_cursor_path": "response_metadata.next_cursor",
        "page_size": 100
      },
      "id": "VARCHAR,$key",
      "name": "VARCHAR",
      "domain": "VARCHAR",
      "email_domain": "VARCHAR",
      "icon": "VARCHAR",
      "is_verified": "BOOLEAN",
      "discoverable": "VARCHAR",
      "enterprise_id": "VARCHAR",
      "enterprise_name": "VARCHAR",
      "is_enterprise": "INTEGER",
      "created": "BIGINT",
      "archived": "BOOLEAN",
      "deleted": "BOOLEAN",
      "teams": "VARCHAR"
    },
    "DND_TEAM_INFO": {
      "$path": ["/dnd.teamInfo"],
      "$data_path": "users",
      "ROWID": "VARCHAR,$key",
      "user_data": "VARCHAR"
    }
  }
}