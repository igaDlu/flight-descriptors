{
  "$connector_name": "Pipedrive CRM API Connector",
  "$connector_label": "Pipedrive CRM",
  "$connector_description": "Connector for Pipedrive CRM API - provides access to deals, persons, organizations, activities, and pipeline data",
  "$hostname": "https://api.pipedrive.com",
  "$authentication": "api_key",
  "$tables": {
    "DEALS": {
      "$path": ["/v1/deals"],
      "$data_path": "data",
      "$pagination": {
        "type": "offset",
        "offset_param": "start",
        "limit_param": "limit",
        "page_size": 100,
        "initial_offset": 0
      },
      "id": "INTEGER,$key",
      "title": "VARCHAR",
      "value": "DECIMAL",
      "currency": "VARCHAR",
      "status": "VARCHAR",
      "stage_id": "INTEGER",
      "pipeline_id": "INTEGER",
      "person_id": "INTEGER",
      "org_id": "INTEGER",
      "user_id": "INTEGER",
      "add_time": "TIMESTAMP",
      "update_time": "TIMESTAMP",
      "close_time": "TIMESTAMP",
      "won_time": "TIMESTAMP",
      "lost_time": "TIMESTAMP",
      "expected_close_date": "DATE",
      "probability": "DECIMAL"
    },
    "PERSONS": {
      "$path": ["/v1/persons"],
      "$data_path": "data",
      "$pagination": {
        "type": "offset",
        "offset_param": "start",
        "limit_param": "limit",
        "page_size": 100,
        "initial_offset": 0
      },
      "id": "INTEGER,$key",
      "name": "VARCHAR",
      "first_name": "VARCHAR",
      "last_name": "VARCHAR",
      "email": "VARCHAR",
      "phone": "VARCHAR",
      "org_id": "INTEGER",
      "owner_id": "INTEGER",
      "add_time": "TIMESTAMP",
      "update_time": "TIMESTAMP",
      "visible_to": "VARCHAR",
      "label": "INTEGER"
    },
    "ORGANIZATIONS": {
      "$path": ["/v1/organizations"],
      "$data_path": "data",
      "$pagination": {
        "type": "offset",
        "offset_param": "start",
        "limit_param": "limit",
        "page_size": 100,
        "initial_offset": 0
      },
      "id": "INTEGER,$key",
      "name": "VARCHAR",
      "address": "VARCHAR",
      "owner_id": "INTEGER",
      "add_time": "TIMESTAMP",
      "update_time": "TIMESTAMP",
      "visible_to": "VARCHAR",
      "label": "INTEGER",
      "people_count": "INTEGER",
      "activities_count": "INTEGER",
      "done_activities_count": "INTEGER",
      "undone_activities_count": "INTEGER",
      "closed_deals_count": "INTEGER",
      "open_deals_count": "INTEGER"
    },
    "ACTIVITIES": {
      "$path": ["/v1/activities"],
      "$data_path": "data",
      "$pagination": {
        "type": "offset",
        "offset_param": "start",
        "limit_param": "limit",
        "page_size": 100,
        "initial_offset": 0
      },
      "id": "INTEGER,$key",
      "subject": "VARCHAR",
      "type": "VARCHAR",
      "done": "BOOLEAN",
      "due_date": "DATE",
      "due_time": "TIME",
      "duration": "VARCHAR",
      "deal_id": "INTEGER",
      "person_id": "INTEGER",
      "org_id": "INTEGER",
      "user_id": "INTEGER",
      "add_time": "TIMESTAMP",
      "update_time": "TIMESTAMP",
      "marked_as_done_time": "TIMESTAMP",
      "note": "VARCHAR"
    },
    "PIPELINES": {
      "$path": ["/v1/pipelines"],
      "$data_path": "data",
      "id": "INTEGER,$key",
      "name": "VARCHAR",
      "url_title": "VARCHAR",
      "order_nr": "INTEGER",
      "active": "BOOLEAN",
      "deal_probability": "BOOLEAN",
      "add_time": "TIMESTAMP",
      "update_time": "TIMESTAMP"
    },
    "STAGES": {
      "$path": ["/v1/stages"],
      "$data_path": "data",
      "id": "INTEGER,$key",
      "name": "VARCHAR",
      "pipeline_id": "INTEGER",
      "deal_probability": "INTEGER",
      "rotten_flag": "BOOLEAN",
      "rotten_days": "INTEGER",
      "order_nr": "INTEGER",
      "active_flag": "BOOLEAN",
      "add_time": "TIMESTAMP",
      "update_time": "TIMESTAMP"
    },
    "PRODUCTS": {
      "$path": ["/v1/products"],
      "$data_path": "data",
      "$pagination": {
        "type": "offset",
        "offset_param": "start",
        "limit_param": "limit",
        "page_size": 100,
        "initial_offset": 0
      },
      "id": "INTEGER,$key",
      "name": "VARCHAR",
      "code": "VARCHAR",
      "unit": "VARCHAR",
      "tax": "DECIMAL",
      "active_flag": "BOOLEAN",
      "visible_to": "VARCHAR",
      "owner_id": "INTEGER",
      "add_time": "TIMESTAMP",
      "update_time": "TIMESTAMP"
    },
    "NOTES": {
      "$path": ["/v1/notes"],
      "$data_path": "data",
      "$pagination": {
        "type": "offset",
        "offset_param": "start",
        "limit_param": "limit",
        "page_size": 100,
        "initial_offset": 0
      },
      "id": "INTEGER,$key",
      "content": "VARCHAR",
      "deal_id": "INTEGER",
      "person_id": "INTEGER",
      "org_id": "INTEGER",
      "user_id": "INTEGER",
      "add_time": "TIMESTAMP",
      "update_time": "TIMESTAMP",
      "active_flag": "BOOLEAN",
      "pinned_to_deal_flag": "BOOLEAN",
      "pinned_to_person_flag": "BOOLEAN",
      "pinned_to_organization_flag": "BOOLEAN"
    },
    "USERS": {
      "$path": ["/v1/users"],
      "$data_path": "data",
      "id": "INTEGER,$key",
      "name": "VARCHAR",
      "email": "VARCHAR",
      "active_flag": "BOOLEAN",
      "created": "TIMESTAMP",
      "modified": "TIMESTAMP",
      "role_id": "INTEGER",
      "timezone_name": "VARCHAR",
      "locale": "VARCHAR"
    }
  }
}