{
  "$connector_name": "Amplitude Analytics API Connector",
  "$connector_label": "Amplitude Analytics",
  "$connector_description": "Connector for Amplitude Analytics API - provides access to events, user properties, cohorts, and analytics data",
  "$hostname": "https://amplitude.com",
  "$authentication": "api_key",
  "$tables": {
    "EVENTS": {
      "$path": ["/api/2/events"],
      "$data_path": "data",
      "event_id": "VARCHAR,$key",
      "event_type": "VARCHAR",
      "user_id": "VARCHAR",
      "device_id": "VARCHAR",
      "time": "BIGINT",
      "event_properties": "VARCHAR",
      "user_properties": "VARCHAR",
      "amplitude_id": "BIGINT",
      "session_id": "BIGINT",
      "platform": "VARCHAR",
      "os_name": "VARCHAR",
      "os_version": "VARCHAR",
      "device_brand": "VARCHAR",
      "device_manufacturer": "VARCHAR",
      "device_model": "VARCHAR",
      "carrier": "VARCHAR",
      "country": "VARCHAR",
      "region": "VARCHAR",
      "city": "VARCHAR",
      "dma": "VARCHAR",
      "language": "VARCHAR"
    },
    "USER_PROPERTIES": {
      "$path": ["/api/2/userproperties"],
      "$data_path": "data",
      "user_id": "VARCHAR,$key",
      "amplitude_id": "BIGINT",
      "user_properties": "VARCHAR",
      "last_seen": "BIGINT",
      "platform": "VARCHAR",
      "os_name": "VARCHAR",
      "device_type": "VARCHAR",
      "country": "VARCHAR",
      "city": "VARCHAR",
      "region": "VARCHAR"
    },
    "COHORTS": {
      "$path": ["/api/3/cohorts"],
      "$data_path": "cohorts",
      "id": "VARCHAR,$key",
      "name": "VARCHAR",
      "description": "VARCHAR",
      "size": "INTEGER",
      "created_at": "TIMESTAMP",
      "last_computed": "TIMESTAMP",
      "last_modified": "TIMESTAMP",
      "is_predictive": "BOOLEAN",
      "is_published": "BOOLEAN",
      "location_id": "VARCHAR"
    },
    "ACTIVE_USERS": {
      "$path": ["/api/2/users"],
      "$data_path": "data",
      "user_id": "VARCHAR,$key",
      "amplitude_id": "BIGINT",
      "last_used": "BIGINT",
      "usage_time": "INTEGER",
      "platform": "VARCHAR",
      "os": "VARCHAR",
      "device": "VARCHAR",
      "country": "VARCHAR",
      "city": "VARCHAR",
      "region": "VARCHAR"
    },
    "REVENUE": {
      "$path": ["/api/2/revenue"],
      "$data_path": "data",
      "event_id": "VARCHAR,$key",
      "user_id": "VARCHAR",
      "device_id": "VARCHAR",
      "time": "BIGINT",
      "revenue": "DECIMAL",
      "revenue_type": "VARCHAR",
      "product_id": "VARCHAR",
      "quantity": "INTEGER",
      "price": "DECIMAL",
      "event_properties": "VARCHAR"
    },
    "ANNOTATIONS": {
      "$path": ["/api/2/annotations"],
      "$data_path": "data",
      "id": "INTEGER,$key",
      "label": "VARCHAR",
      "details": "VARCHAR",
      "date": "DATE",
      "created_by": "VARCHAR"
    }
  }
}