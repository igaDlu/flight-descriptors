{
  "$connector_name": "Jenkins API Connector",
  "$connector_label": "Jenkins API",
  "$connector_description": "Connector for Jenkins REST API - provides access to jobs, builds, nodes, queues, users, views, and system information",
  "$hostname": "https://{jenkins-server}",
  "$authentication": "basic",
  "$tables": {
    "JOBS": {
      "$path": ["/api/json"],
      "$data_path": "jobs",
      "name": "VARCHAR,$key",
      "url": "VARCHAR",
      "color": "VARCHAR",
      "_class": "VARCHAR",
      "fullName": "VARCHAR",
      "displayName": "VARCHAR",
      "description": "VARCHAR",
      "buildable": "BOOLEAN",
      "inQueue": "BOOLEAN",
      "keepDependencies": "BOOLEAN",
      "nextBuildNumber": "INTEGER",
      "concurrentBuild": "BOOLEAN",
      "disabled": "BOOLEAN"
    },
    "JOB_DETAILS": {
      "$path": ["/job/{job-name}/api/json"],
      "name": "VARCHAR,$key",
      "url": "VARCHAR",
      "displayName": "VARCHAR",
      "fullDisplayName": "VARCHAR",
      "fullName": "VARCHAR",
      "description": "VARCHAR",
      "buildable": "BOOLEAN",
      "color": "VARCHAR",
      "_class": "VARCHAR",
      "inQueue": "BOOLEAN",
      "keepDependencies": "BOOLEAN",
      "nextBuildNumber": "INTEGER",
      "concurrentBuild": "BOOLEAN",
      "disabled": "BOOLEAN",
      "downstreamProjects": "VARCHAR",
      "upstreamProjects": "VARCHAR",
      "scm": "VARCHAR",
      "actions": "VARCHAR",
      "property": "VARCHAR",
      "queueItem": "VARCHAR",
      "healthReport": "VARCHAR",
      "builds": "VARCHAR",
      "firstBuild": "VARCHAR",
      "lastBuild": "VARCHAR",
      "lastCompletedBuild": "VARCHAR",
      "lastFailedBuild": "VARCHAR",
      "lastStableBuild": "VARCHAR",
      "lastSuccessfulBuild": "VARCHAR",
      "lastUnstableBuild": "VARCHAR",
      "lastUnsuccessfulBuild": "VARCHAR"
    },
    "BUILDS": {
      "$path": ["/job/{job-name}/api/json"],
      "$data_path": "builds",
      "number": "INTEGER,$key",
      "url": "VARCHAR",
      "displayName": "VARCHAR",
      "_class": "VARCHAR"
    },
    "BUILD_DETAILS": {
      "$path": ["/job/{job-name}/{build-number}/api/json"],
      "number": "INTEGER,$key",
      "id": "VARCHAR",
      "url": "VARCHAR",
      "displayName": "VARCHAR",
      "fullDisplayName": "VARCHAR",
      "description": "VARCHAR",
      "building": "BOOLEAN",
      "duration": "BIGINT",
      "estimatedDuration": "BIGINT",
      "timestamp": "BIGINT",
      "result": "VARCHAR",
      "builtOn": "VARCHAR",
      "keepLog": "BOOLEAN",
      "queueId": "INTEGER",
      "_class": "VARCHAR",
      "actions": "VARCHAR",
      "artifacts": "VARCHAR",
      "changeSet": "VARCHAR",
      "culprits": "VARCHAR",
      "nextBuild": "VARCHAR",
      "previousBuild": "VARCHAR",
      "executor": "VARCHAR",
      "mavenArtifacts": "VARCHAR",
      "mavenVersionUsed": "VARCHAR",
      "fingerprint": "VARCHAR"
    },
    "BUILD_CONSOLE_LOG": {
      "$path": ["/job/{job-name}/{build-number}/logText/progressiveText"],
      "ROWID": "VARCHAR,$key",
      "text": "VARCHAR"
    },
    "NODES": {
      "$path": ["/computer/api/json"],
      "$data_path": "computer",
      "displayName": "VARCHAR,$key",
      "description": "VARCHAR",
      "executors": "VARCHAR",
      "icon": "VARCHAR",
      "iconClassName": "VARCHAR",
      "idle": "BOOLEAN",
      "jnlpAgent": "BOOLEAN",
      "launchSupported": "BOOLEAN",
      "loadStatistics": "VARCHAR",
      "manualLaunchAllowed": "BOOLEAN",
      "monitorData": "VARCHAR",
      "numExecutors": "INTEGER",
      "offline": "BOOLEAN",
      "offlineCause": "VARCHAR",
      "offlineCauseReason": "VARCHAR",
      "oneOffExecutors": "VARCHAR",
      "temporarilyOffline": "BOOLEAN",
      "_class": "VARCHAR"
    },
    "NODE_DETAILS": {
      "$path": ["/computer/{node-name}/api/json"],
      "displayName": "VARCHAR,$key",
      "description": "VARCHAR",
      "assignedLabels": "VARCHAR",
      "mode": "VARCHAR",
      "nodeDescription": "VARCHAR",
      "nodeName": "VARCHAR",
      "numExecutors": "INTEGER",
      "labelString": "VARCHAR",
      "launcher": "VARCHAR",
      "retentionStrategy": "VARCHAR",
      "nodeProperties": "VARCHAR",
      "userId": "VARCHAR",
      "userIdCause": "VARCHAR",
      "icon": "VARCHAR",
      "iconClassName": "VARCHAR",
      "idle": "BOOLEAN",
      "jnlpAgent": "BOOLEAN",
      "launchSupported": "BOOLEAN",
      "loadStatistics": "VARCHAR",
      "manualLaunchAllowed": "BOOLEAN",
      "monitorData": "VARCHAR",
      "offline": "BOOLEAN",
      "offlineCause": "VARCHAR",
      "offlineCauseReason": "VARCHAR",
      "oneOffExecutors": "VARCHAR",
      "temporarilyOffline": "BOOLEAN",
      "absoluteRemotePath": "VARCHAR",
      "_class": "VARCHAR"
    },
    "QUEUE": {
      "$path": ["/queue/api/json"],
      "$data_path": "items",
      "id": "INTEGER,$key",
      "inQueueSince": "BIGINT",
      "params": "VARCHAR",
      "stuck": "BOOLEAN",
      "url": "VARCHAR",
      "why": "VARCHAR",
      "blocked": "BOOLEAN",
      "buildable": "BOOLEAN",
      "buildableStartMilliseconds": "BIGINT",
      "pending": "BOOLEAN",
      "task": "VARCHAR",
      "actions": "VARCHAR",
      "_class": "VARCHAR"
    },
    "USERS": {
      "$path": ["/asynchPeople/api/json"],
      "$data_path": "users",
      "user[]": {
        "absoluteUrl": "VARCHAR",
        "fullName": "VARCHAR"
      },
      "ROWID": "VARCHAR,$key"
    },
    "USER_DETAILS": {
      "$path": ["/user/{username}/api/json"],
      "id": "VARCHAR,$key",
      "fullName": "VARCHAR",
      "description": "VARCHAR",
      "absoluteUrl": "VARCHAR",
      "_class": "VARCHAR",
      "property": "VARCHAR"
    },
    "VIEWS": {
      "$path": ["/api/json"],
      "$data_path": "views",
      "name": "VARCHAR,$key",
      "url": "VARCHAR",
      "description": "VARCHAR",
      "_class": "VARCHAR"
    },
    "VIEW_DETAILS": {
      "$path": ["/view/{view-name}/api/json"],
      "name": "VARCHAR,$key",
      "url": "VARCHAR",
      "description": "VARCHAR",
      "jobs": "VARCHAR",
      "property": "VARCHAR",
      "_class": "VARCHAR"
    },
    "PLUGINS": {
      "$path": ["/pluginManager/api/json"],
      "$data_path": "plugins",
      "shortName": "VARCHAR,$key",
      "longName": "VARCHAR",
      "version": "VARCHAR",
      "url": "VARCHAR",
      "active": "BOOLEAN",
      "enabled": "BOOLEAN",
      "bundled": "BOOLEAN",
      "deleted": "BOOLEAN",
      "downgradable": "BOOLEAN",
      "hasUpdate": "BOOLEAN",
      "pinned": "BOOLEAN",
      "requiredCoreVersion": "VARCHAR",
      "supportsDynamicLoad": "VARCHAR",
      "backupVersion": "VARCHAR",
      "dependencies": "VARCHAR",
      "_class": "VARCHAR"
    },
    "SYSTEM_INFO": {
      "$path": ["/api/json"],
      "ROWID": "VARCHAR,$key",
      "mode": "VARCHAR",
      "nodeDescription": "VARCHAR",
      "nodeName": "VARCHAR",
      "numExecutors": "INTEGER",
      "description": "VARCHAR",
      "quietingDown": "BOOLEAN",
      "slaveAgentPort": "INTEGER",
      "unlabeledLoad": "VARCHAR",
      "useCrumbs": "BOOLEAN",
      "useSecurity": "BOOLEAN",
      "views": "VARCHAR",
      "primaryView": "VARCHAR",
      "assignedLabels": "VARCHAR",
      "_class": "VARCHAR"
    },
    "CREDENTIALS": {
      "$path": ["/credentials/api/json"],
      "$data_path": "credentials",
      "id": "VARCHAR,$key",
      "description": "VARCHAR",
      "displayName": "VARCHAR",
      "fingerprint": "VARCHAR",
      "fullName": "VARCHAR",
      "typeName": "VARCHAR",
      "_class": "VARCHAR"
    },
    "FOLDERS": {
      "$path": ["/api/json"],
      "$data_path": "jobs",
      "name": "VARCHAR,$key",
      "url": "VARCHAR",
      "displayName": "VARCHAR",
      "fullDisplayName": "VARCHAR",
      "fullName": "VARCHAR",
      "description": "VARCHAR",
      "_class": "VARCHAR",
      "healthReport": "VARCHAR",
      "jobs": "VARCHAR",
      "primaryView": "VARCHAR",
      "views": "VARCHAR"
    }
  }
}