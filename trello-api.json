      "name": "VARCHAR",
      "pos": "DOUBLE",
      "shortLink": "VARCHAR",
      "shortUrl": "VARCHAR",
      "start": "TIMESTAMP",
      "subscribed": "BOOLEAN",
      "url": "VARCHAR",
