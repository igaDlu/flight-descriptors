        "canBeOrg": "BOOLEAN",
        "canBePrivate": "BOOLEAN",
        "canInvite": "BOOLEAN"
      },
      "labelNames[]": {
        "green": "VARCHAR",
        "yellow": "VARCHAR",
        "orange": "VARCHAR",
        "red": "VARCHAR",
        "purple": "VARCHAR",
        "blue": "VARCHAR",
        "sky": "VARCHAR",
        "lime": "VARCHAR",
        "pink": "VARCHAR",
        "black": "VARCHAR"
      },
      "starred": "BOOLEAN",
      "limits": "VARCHAR",
      "memberships": "VARCHAR",
      "shortLink": "VARCHAR",
