        "attachmentsByType": "VARCHAR",
        "location": "BOOLEAN",
        "votes": "INTEGER",
        "viewingMemberVoted": "BOOLEAN",
        "subscribed": "BOOLEAN",
        "fogbugz": "VARCHAR",
        "checkItems": "INTEGER",
        "checkItemsChecked": "INTEGER",
        "checkItemsEarliestDue": "TIMESTAMP",
        "comments": "INTEGER",
        "attachments": "INTEGER",
        "description": "BOOLEAN",
