      "bio": "VARCHAR",
      "bioData": "VARCHAR",
      "confirmed": "BOOLEAN",
      "fullName": "VARCHAR",
      "idEnterprise": "VARCHAR",
      "idEnterprisesDeactivated": "VARCHAR",
      "idMemberReferrer": "VARCHAR",
