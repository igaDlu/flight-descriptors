      "status": "VARCHAR",
      "aaId": "VARCHAR",
      "aaEmail": "VARCHAR",
      "avatarSource": "VARCHAR",
      "email": "VARCHAR",
      "gravatarHash": "VARCHAR",
      "idBoards": "VARCHAR",
      "idOrganizations": "VARCHAR",
      "idEnterprisesAdmin": "VARCHAR",
      "limits": "VARCHAR",
      "loginTypes": "VARCHAR",
      "marketingOptIn": "VARCHAR",
      "messagesDismissed": "VARCHAR",
