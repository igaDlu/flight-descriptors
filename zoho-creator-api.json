      "user_type": "VARCHAR",
      "is_admin": "BOOLEAN",
      "is_super_admin": "BOOLEAN"
    },
    "FORMS": {
      "$path": ["/{{account_owner_name}}/{{app_link_name}}/forms"],
      "$data_path": "data",
      "$pagination": {
        "type": "offset",
        "offset_param": "from",
        "limit_param": "limit",
        "page_size": 200,
        "initial_offset": 1
      },
      "form_name": "VARCHAR,$key",
      "form_id": "VARCHAR",
      "link_name": "VARCHAR",
      "display_name": "VARCHAR",
      "description": "VARCHAR",
