{
  "$connector_name": "Zoho Creator API Connector",
  "$connector_label": "Zoho Creator API",
  "$connector_description": "Connector for Zoho Creator API v2 - provides access to workspaces, applications, users, forms, reports, pages, fields, workflows, and integrations within a specific application. Supports multiple Zoho data centers (US, EU, India, Australia, Japan, China).",
  "$hostname": "https://{{api_domain}}/api/v2",
  "$authentication": "oauth2",
  "$connection_properties": [
    {
      "name": "api_domain",
      "label": "API Domain",
      "description": "Your Zoho API domain based on data center (e.g., creator.zoho.com for US, creator.zoho.eu for EU, creator.zoho.in for India, creator.zoho.com.au for Australia, creator.zoho.jp for Japan, creator.zoho.com.cn for China)",
      "type": "string",
      "required": true,
      "default": "creator.zoho.com"
    },
    {
      "name": "account_owner_name",
      "label": "Account Owner Name",
      "description": "The account owner name (username) for accessing workspace and application data. Required for all application-scoped endpoints.",
      "type": "string",
      "required": true
    },
    {
      "name": "app_link_name",
      "label": "Application Link Name",
      "description": "The application link name (URL-friendly name) for accessing forms, reports, pages, fields, and workflows within a specific application. Required for application-scoped data.",
      "type": "string",
      "required": true
    }
  ],
  "$tables": {
    "WORKSPACES": {
      "$path": ["/workspaces"],
      "$data_path": "data",
      "$pagination": {
        "type": "offset",
        "offset_param": "from",
        "limit_param": "limit",
        "page_size": 200,
        "initial_offset": 1
      },
      "workspace_name": "VARCHAR,$key",
      "workspace_id": "VARCHAR",
      "display_name": "VARCHAR",
      "description": "VARCHAR",
      "created_time": "TIMESTAMP",
      "modified_time": "TIMESTAMP",
      "created_by": "VARCHAR",
      "modified_by": "VARCHAR",
      "workspace_url": "VARCHAR",
      "is_default": "BOOLEAN",
      "role": "VARCHAR",
      "applications_count": "INTEGER"
    },
    "APPLICATIONS": {
      "$path": ["/{{account_owner_name}}/applications"],
      "$data_path": "data",
      "$pagination": {
        "type": "offset",
        "offset_param": "from",
        "limit_param": "limit",
        "page_size": 200,
        "initial_offset": 1
      },
      "application_name": "VARCHAR,$key",
      "application_id": "VARCHAR",
      "link_name": "VARCHAR",
      "display_name": "VARCHAR",
      "description": "VARCHAR",
      "workspace_name": "VARCHAR",
      "workspace_id": "VARCHAR",
      "created_time": "TIMESTAMP",
      "modified_time": "TIMESTAMP",
      "created_by": "VARCHAR",
      "modified_by": "VARCHAR",
      "application_url": "VARCHAR",
      "type": "VARCHAR",
      "version": "VARCHAR",
      "status": "VARCHAR",
      "is_template": "BOOLEAN",
      "category": "VARCHAR",
      "forms_count": "INTEGER",
      "reports_count": "INTEGER",
      "pages_count": "INTEGER"
    },
    "USERS": {
      "$path": ["/users"],
      "$data_path": "data",
      "$pagination": {
        "type": "offset",
        "offset_param": "from",
        "limit_param": "limit",
        "page_size": 200,
        "initial_offset": 1
      },
      "user_id": "VARCHAR,$key",
      "email_id": "VARCHAR",
      "display_name": "VARCHAR",
      "first_name": "VARCHAR",
      "last_name": "VARCHAR",
      "role_name": "VARCHAR",
      "role_id": "VARCHAR",
      "status": "VARCHAR",
      "is_confirmed": "BOOLEAN",
      "created_time": "TIMESTAMP",
