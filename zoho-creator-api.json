        "type": "offset",
        "offset_param": "from",
        "limit_param": "limit",
        "page_size": 200,
        "initial_offset": 1
      },
      "report_name": "VARCHAR,$key",
      "report_id": "VARCHAR",
      "link_name": "VARCHAR",
      "display_name": "VARCHAR",
      "description": "VARCHAR",
      "application_name": "VARCHAR",
