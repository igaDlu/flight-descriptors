      "approved_date": "DATE",
      "description": "VARCHAR",
      "origin_id": "INTEGER",
      "origin_data": "VARCHAR",
      "created_by[]": {
        "id": "INTEGER",
        "name": "VARCHAR"
      },
      "contract[]": {
        "id": "INTEGER",
        "title": "VARCHAR"
      },
      "change_order_packages": "VARCHAR",
      "private": "BOOLEAN"
    },
    "PUNCH_ITEMS": {
      "$path": ["/rest/v1.0/projects/{project_id}/punch_items"],
      "$pagination": {
        "type": "page",
        "page_param": "page",
        "limit_param": "per_page",
        "page_size": 100,
        "initial_page": 1
      },
      "id": "INTEGER,$key",
      "number": "INTEGER",
      "title": "VARCHAR",
      "status": "VARCHAR",
      "description": "VARCHAR",
      "due_date": "DATE",
      "created_at": "TIMESTAMP",
      "updated_at": "TIMESTAMP",
      "assignee[]": {
        "id": "INTEGER",
        "name": "VARCHAR"
      },
      "responsible_contractor[]": {
        "id": "INTEGER",
        "name": "VARCHAR"
      },
      "created_by[]": {
        "id": "INTEGER",
        "name": "VARCHAR"
      },
      "location[]": {
        "id": "INTEGER",
        "name": "VARCHAR"
      },
      "trade": "VARCHAR",
      "cost_code": "VARCHAR",
      "private": "BOOLEAN",
      "attachments": "VARCHAR"
    },
    "MEETINGS": {
      "$path": ["/rest/v1.0/projects/{project_id}/meetings"],
      "$pagination": {
        "type": "page",
        "page_param": "page",
        "limit_param": "per_page",
        "page_size": 100,
        "initial_page": 1
      },
      "id": "INTEGER,$key",
      "title": "VARCHAR",
      "meeting_date": "TIMESTAMP",
      "location": "VARCHAR",
      "created_at": "TIMESTAMP",
      "updated_at": "TIMESTAMP",
      "created_by[]": {
        "id": "INTEGER",
        "name": "VARCHAR"
      },
      "meeting_type": "VARCHAR",
      "private": "BOOLEAN",
      "attendees": "VARCHAR",
      "categories": "VARCHAR"
    },
    "DAILY_LOGS": {
      "$path": ["/rest/v1.0/projects/{project_id}/daily_logs"],
      "$pagination": {
        "type": "page",
        "page_param": "page",
        "limit_param": "per_page",
        "page_size": 100,
        "initial_page": 1
      },
      "id": "INTEGER,$key",
      "log_date": "DATE",
      "created_at": "TIMESTAMP",
      "updated_at": "TIMESTAMP",
