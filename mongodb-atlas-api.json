{
  "$connector_name": "MongoDB Atlas API Connector",
  "$connector_label": "MongoDB Atlas API",
  "$connector_description": "Connector for MongoDB Atlas Admin API v2 - provides access to organizations, projects, clusters, database users, backups, events, alerts, and more",
  "$hostname": "https://cloud.mongodb.com",
  "$authentication": "basic",
  "$tables": {
    "PROJECTS": {
      "$path": ["/api/atlas/v2/groups"],
      "$data_path": "results",
      "$pagination": {
        "type": "page",
        "page_param": "pageNum",
        "limit_param": "itemsPerPage",
        "page_size": 100,
        "initial_page": 1
      },
      "id": "VARCHAR,$key",
      "name": "VARCHAR",
      "orgId": "VARCHAR",
      "clusterCount": "INTEGER",
      "created": "TIMESTAMP",
      "links": "VARCHAR"
    },
    "CLUSTERS": {
      "$path": ["/api/atlas/v2/groups/{groupId}/clusters"],
      "$data_path": "results",
      "$pagination": {
        "type": "page",
        "page_param": "pageNum",
        "limit_param": "itemsPerPage",
        "page_size": 100,
        "initial_page": 1
      },
      "id": "VARCHAR,$key",
      "name": "VARCHAR",
      "groupId": "VARCHAR",
      "clusterType": "VARCHAR",
      "mongoDBVersion": "VARCHAR",
      "mongoDBMajorVersion": "VARCHAR",
      "createDate": "TIMESTAMP",
      "stateName": "VARCHAR",
      "paused": "BOOLEAN",
      "pitEnabled": "BOOLEAN",
      "backupEnabled": "BOOLEAN",
      "providerSettings[]": {
        "providerName": "VARCHAR",
        "instanceSizeName": "VARCHAR",
        "regionName": "VARCHAR",
        "diskIOPS": "INTEGER",
        "encryptEBSVolume": "BOOLEAN",
        "volumeType": "VARCHAR"
      },
      "replicationSpecs": "VARCHAR",
      "connectionStrings[]": {
        "standard": "VARCHAR",
        "standardSrv": "VARCHAR",
        "private": "VARCHAR",
        "privateSrv": "VARCHAR"
      },
      "diskSizeGB": "DOUBLE",
      "numShards": "INTEGER",
      "replicationFactor": "INTEGER",
      "autoScaling[]": {
        "diskGBEnabled": "BOOLEAN"
      },
      "labels": "VARCHAR",
      "links": "VARCHAR"
    },
    "DATABASE_USERS": {
      "$path": ["/api/atlas/v2/groups/{groupId}/databaseUsers"],
      "$data_path": "results",
      "$pagination": {
        "type": "page",
        "page_param": "pageNum",
        "limit_param": "itemsPerPage",
