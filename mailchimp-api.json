      "id": "VARCHAR,$key",
      "create_time": "TIMESTAMP",
      "start_time": "TIMESTAMP",
      "status": "VARCHAR",
      "emails_sent": "INTEGER",
      "recipients[]": {
        "list_id": "VARCHAR",
        "list_is_active": "BOOLEAN",
        "list_name": "VARCHAR",
        "segment_opts": "VARCHAR",
        "store_id": "VARCHAR"
      },
      "settings[]": {
        "title": "VARCHAR",
