{
  "$connector_name": "Mailchimp Connector",
  "$connector_label": "Mailchimp Marketing API",
  "$connector_description": "Mailchimp Marketing API Connector. Docs: https://mailchimp.com/developer/marketing/api/",
  "$hostname": "https://{{server_prefix}}.api.mailchimp.com/3.0",
  "$authentication": "basic",
  "$connection_properties": [
    {
      "name": "server_prefix",
      "type": "string",
      "required": true,
      "label": "Server Prefix",
      "description": "Your Mailchimp server prefix (e.g., 'us19'). Find this in your Mailchimp account URL."
    }
  ],
  "$tables": {
    "CAMPAIGNS": {
      "$path": ["/campaigns"],
      "$data_path": "campaigns",
      "$pagination": {
        "type": "offset",
        "offset_param": "offset",
        "limit_param": "count",
        "page_size": 100,
        "initial_offset": 0
      },
      "id": "VARCHAR,$key",
      "web_id": "INTEGER",
      "type": "VARCHAR",
      "create_time": "TIMESTAMP",
      "archive_url": "VARCHAR",
      "long_archive_url": "VARCHAR",
      "status": "VARCHAR",
      "emails_sent": "INTEGER",
      "send_time": "TIMESTAMP",
      "content_type": "VARCHAR",
      "needs_block_refresh": "BOOLEAN",
      "resendable": "BOOLEAN",
      "recipients[]": {
        "list_id": "VARCHAR",
        "list_is_active": "BOOLEAN",
        "list_name": "VARCHAR",
        "segment_text": "VARCHAR",
        "recipient_count": "INTEGER"
      },
      "settings[]": {
        "subject_line": "VARCHAR",
        "preview_text": "VARCHAR",
        "title": "VARCHAR",
        "from_name": "VARCHAR",
        "reply_to": "VARCHAR",
        "use_conversation": "BOOLEAN",
        "to_name": "VARCHAR",
        "folder_id": "VARCHAR",
        "authenticate": "BOOLEAN",
        "auto_footer": "BOOLEAN",
        "inline_css": "BOOLEAN",
        "auto_tweet": "BOOLEAN",
        "fb_comments": "BOOLEAN",
        "timewarp": "BOOLEAN",
        "template_id": "INTEGER",
        "drag_and_drop": "BOOLEAN"
      },
      "tracking[]": {
        "opens": "BOOLEAN",
        "html_clicks": "BOOLEAN",
        "text_clicks": "BOOLEAN",
        "goal_tracking": "BOOLEAN",
        "ecomm360": "BOOLEAN",
        "google_analytics": "VARCHAR",
        "clicktale": "VARCHAR"
      }
    },
    "LISTS": {
      "$path": ["/lists"],
      "$data_path": "lists",
      "$pagination": {
        "type": "offset",
        "offset_param": "offset",
        "limit_param": "count",
        "page_size": 100,
        "initial_offset": 0
      },
      "id": "VARCHAR,$key",
      "web_id": "INTEGER",
      "name": "VARCHAR",
      "contact[]": {
        "company": "VARCHAR",
        "address1": "VARCHAR",
        "address2": "VARCHAR",
        "city": "VARCHAR",
        "state": "VARCHAR",
        "zip": "VARCHAR",
        "country": "VARCHAR",
        "phone": "VARCHAR"
      },
      "permission_reminder": "VARCHAR",
      "use_archive_bar": "BOOLEAN",
      "campaign_defaults[]": {
        "from_name": "VARCHAR",
        "from_email": "VARCHAR",
        "subject": "VARCHAR",
        "language": "VARCHAR"
      },
      "notify_on_subscribe": "VARCHAR",
      "notify_on_unsubscribe": "VARCHAR",
      "date_created": "TIMESTAMP",
      "list_rating": "INTEGER",
      "email_type_option": "BOOLEAN",
      "subscribe_url_short": "VARCHAR",
      "subscribe_url_long": "VARCHAR",
      "beamer_address": "VARCHAR",
      "visibility": "VARCHAR",
      "double_optin": "BOOLEAN",
      "has_welcome": "BOOLEAN",
