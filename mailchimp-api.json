        "unsubscribe_count_since_send": "INTEGER",
        "cleaned_count_since_send": "INTEGER",
        "campaign_count": "INTEGER",
        "campaign_last_sent": "TIMESTAMP",
        "merge_field_count": "INTEGER",
        "avg_sub_rate": "DOUBLE",
        "avg_unsub_rate": "DOUBLE",
        "target_sub_rate": "DOUBLE",
        "open_rate": "DOUBLE",
        "click_rate": "DOUBLE",
        "last_sub_date": "TIMESTAMP",
        "last_unsub_date": "TIMESTAMP"
      }
    },
    "TEMPLATES": {
      "$path": ["/templates"],
      "$data_path": "templates",
      "$pagination": {
        "type": "offset",
        "offset_param": "offset",
        "limit_param": "count",
        "page_size": 100,
        "initial_offset": 0
