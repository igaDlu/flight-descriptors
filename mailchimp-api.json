        "to_name": "VARCHAR",
        "authenticate": "BOOLEAN",
        "auto_footer": "BOOLEAN",
        "inline_css": "BOOLEAN"
      },
      "tracking[]": {
        "opens": "BOOLEAN",
        "html_clicks": "BOOLEAN",
        "text_clicks": "BOOLEAN",
