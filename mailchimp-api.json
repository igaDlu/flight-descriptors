        "bounce_rate": "DOUBLE",
        "unopen_rate": "DOUBLE",
        "unsub_rate": "DOUBLE",
        "abuse_rate": "DOUBLE"
      },
      "list_stats[]": {
        "sub_rate": "DOUBLE",
