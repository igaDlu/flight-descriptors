{
  "$connector_name": "Splunk REST API Connector",
  "$connector_label": "Splunk",
  "$connector_description": "Connector for Splunk REST API - provides access to search jobs, saved searches, alerts, indexes, and configuration data",
  "$hostname": "https://your-splunk-instance.com:8089",
  "$authentication": "basic",
  "$tables": {
    "SEARCH_JOBS": {
      "$path": ["/services/search/jobs"],
      "$data_path": "entry",
      "name": "VARCHAR,$key",
      "id": "VARCHAR",
      "title": "VARCHAR",
      "updated": "TIMESTAMP",
      "published": "TIMESTAMP",
      "author": "VARCHAR",
      "content": "VARCHAR"
    },
